rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function usernamePattern(name) {
      return name.matches('^[a-z0-9_.]{3,20}$');
    }

    match /usernames/{username} {
      allow read: if true;

      allow create: if isSignedIn()
        && usernamePattern(username)
        && request.resource.data.keys().hasOnly(['uid'])
        && request.resource.data.uid == request.auth.uid;

      allow update: if isOwner(resource.data.uid)
        && request.resource.data.uid == resource.data.uid;

      allow delete: if isOwner(resource.data.uid);
    }

    match /users/{uid} {
      allow get: if isSignedIn();

      allow list: if isSignedIn();

      allow create: if isOwner(uid)
        && request.resource.data.keys().hasOnly(
             ['displayName', 'username', 'elo', 'stats', 'createdAt']
           )
        && request.resource.data.username is string
        && usernamePattern(request.resource.data.username)
        && request.resource.data.displayName is string
        && request.resource.data.elo.tennis == 1200
        && request.resource.data.elo.padel == 1200
        && request.resource.data.stats.matchesPlayed == 0;

      allow update: if isOwner(uid)
        && request.resource.data.username == resource.data.username
        && request.resource.data.elo == resource.data.elo
        && request.resource.data.stats == resource.data.stats
        && request.resource.data.createdAt == resource.data.createdAt;

      allow delete: if isOwner(uid);
    }

    match /friendships/{friendshipId} {
      function idMatchesParticipants(parts) {
        return friendshipId.split('_').size() == 2
          && friendshipId.split('_')[0] in parts
          && friendshipId.split('_')[1] in parts
          && friendshipId.split('_')[0] < friendshipId.split('_')[1];
      }

      allow get: if isSignedIn()
        && (resource == null || request.auth.uid in resource.data.participants);

      allow list: if isSignedIn()
        && request.auth.uid in resource.data.participants;

      allow create: if isSignedIn()
        && request.resource.data.keys().hasOnly(
             ['participants', 'status', 'requestedBy', 'createdAt']
           )
        && request.resource.data.participants.size() == 2
        && request.auth.uid in request.resource.data.participants
        && request.resource.data.requestedBy == request.auth.uid
        && request.resource.data.status == 'pending'
        && idMatchesParticipants(request.resource.data.participants);

      allow update: if isSignedIn()
        && request.auth.uid in resource.data.participants
        && request.auth.uid != resource.data.requestedBy
        && resource.data.status == 'pending'
        && request.resource.data.status == 'accepted'
        && request.resource.data.participants == resource.data.participants
        && request.resource.data.requestedBy == resource.data.requestedBy
        && request.resource.data.createdAt == resource.data.createdAt
        && request.resource.data.keys().hasOnly(
             ['participants', 'status', 'requestedBy', 'createdAt', 'acceptedAt']
           );

      allow delete: if isSignedIn()
        && request.auth.uid in resource.data.participants;
    }

    match /matches/{matchId} {
      allow get, list: if isSignedIn()
        && request.auth.uid in resource.data.players;

      allow create: if isSignedIn()
        && request.resource.data.keys().hasOnly(
             ['matchId', 'sport', 'format', 'players', 'playerNames',
              'winner', 'score', 'startedAt', 'finishedAt', 'status', 'createdBy']
           )
        && request.resource.data.matchId == matchId
        && request.resource.data.createdBy == request.auth.uid
        && request.auth.uid in request.resource.data.players
        && request.resource.data.players.size() == 2
        && request.resource.data.status == 'confirmed'
        && request.resource.data.sport in ['tennis', 'padel'];

      allow update, delete: if false;
    }
  }
}
